FORGE_SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars
# Set to true only when Forge is served over HTTPS
# FORGE_SESSION_SECURE_COOKIE=false
FORGE_ADMIN_USERNAME=admin
FORGE_ADMIN_PASSWORD=admin
FORGE_CURSOR_API_KEY=
FORGE_GIT_USER_NAME=Forge Agent
FORGE_GIT_USER_EMAIL=forge-agent@localhost
# GitHub HTTPS auth for clone/fetch/push (use one of these)
FORGE_GITHUB_TOKEN=
# FORGE_GIT_PASSWORD=
# FORGE_GIT_USERNAME=git
# Host paths for Cursor agent (auto-detected from ~/.local/bin/agent when unset)
# FORGE_CURSOR_AGENT_DIR=/home/you/.local/share/cursor-agent/versions/VERSION
# FORGE_CURSOR_CONFIG_DIR=/home/you/.config/cursor
HOST_PORT=3000
# Commit SHA of the running Forge build (set automatically by build.sh / deploy.sh)
# FORGE_COMMIT_SHA=
# GitHub repo for Forge self-updates (owner/repo)
# FORGE_SELF_REPO=your-org/forge
# FORGE_SELF_BRANCH=main
# Staging port used during self-update health checks (default 3466)
# FORGE_STAGING_PORT=3466
# Caddy admin API (GET /config/, POST /load)
FORGE_CADDY_ADMIN_URL=http://127.0.0.1:2019
# JSON access log file to tail in Global settings → Access logs (fallback when push ingest is off)
# FORGE_CADDY_ACCESS_LOG_PATH=/var/log/caddy/access.log
# Push ingest token for POST /api/caddy/logs/ingest (preferred; in-memory only)
# FORGE_CADDY_LOG_INGEST_TOKEN=change-me-to-a-random-string

# Bearer token for the Forge Ops API (/api/ops/*). Agents use this to deploy, monitor, and configure projects.
# FORGE_OPS_API_TOKEN=change-me-to-a-random-string
# FORGE_OPS_API_BASE=http://127.0.0.1:3000
# TCP port Forge listens on for Caddy "Push to Forge" net writer (default 3999)
# FORGE_CADDY_LOG_TCP_PORT=3999
# Host container socket (auto-detected by deploy.sh when unset)
# DOCKER_SOCKET=/run/user/1000/podman/podman.sock
# FORGE_DOCKER_SOCKET=/data/.skip-docker-socket  # skip-probe sentinel; host socket mounts at /var/run/docker.sock
# FORGE_DOCKER_USE_SOCKET=1  # opt in to prefer bind-mounted socket over DOCKER_HOST
# Podman TCP API port for in-container docker compose (deploy.sh installs a systemd user service)
# FORGE_PODMAN_API_PORT=18765
